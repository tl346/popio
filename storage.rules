rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /profileImages/{userId}.jpg {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /eventImages/{eventId}.jpg {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /menuImages/{eventId}.jpg {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /eventContributionImages/{contributionId}.jpg {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
